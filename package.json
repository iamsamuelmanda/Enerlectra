{
  "name": "enerlectra-mvp",
  "version": "1.0.0",
  "description": "MVP for Zambia's Energy Internet",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:core": "ts-node --esm ./enerlectra-core/src/server.ts",
    "dev:server": "tsx ./server/index.ts",
    "db:migrate": "psql \"$DATABASE_URL\" -f enerlectra-core/src/persistence/schema/001_marketplace_schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -f enerlectra-core/src/persistence/schema/003_seed_data.sql",
    "test": "jest",
    "test:security": "node src/security/securityTest.ts",
    "test:api": "node test/api-tests.js",
    "lint": "eslint \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.94.1",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "express": "^4.22.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "leaflet.markercluster": "^1.5.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "rate-limiter-flexible": "^9.0.0",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^29.5.8",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/socket.io": "^3.0.1",
    "@types/uuid": "^9.0.7",
    "hardhat": "^2.27.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=8.0.0"
  },

  "keywords": [
    "energy",
    "trading",
    "blockchain",
    "africa",
    "renewable",
    "api"
  ],
  "author": "Enerlectra Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamsamuelmanda/EnerlectraTrade.git"
  },
  "directories": {
    "test": "test"
  },
  "bugs": {
    "url": "https://github.com/iamsamuelmanda/EnerlectraTrade/issues"
  },
  "homepage": "https://github.com/iamsamuelmanda/EnerlectraTrade#readme"
}
